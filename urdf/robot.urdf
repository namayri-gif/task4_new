<?xml version="1.0"?>
<robot name="techdojo_robot">

    <gazebo>
        <plugin name="gz::sim::systems::DiffDrive" filename="gz-sim-diff-drive-system">
        <!-- axle 1-->
         <left_joint>left_front_wheel_joint</left_joint>
         <right_joint>right_front_wheel_joint</right_joint>
        <!-- axle 2-->
         <left_joint>left_back_wheel_joint</left_joint>
         <right_joint>right_back_wheel_joint</right_joint>

         <wheel_separation>0.52</wheel_separation>
         <wheel_diameter>0.14</wheel_diameter>

         <topic>/cmd_vel</topic>

         <odom_frame>odom</odom_frame>
         <robot_base_frame>base_footprint</robot_base_frame>

         <publish_odom>true</publish_odom>
         <publish_odom_tf>true</publish_odom_tf>

         <update_rate>50</update_rate>

        <!--Kinematics-->
         <max_linear_velocity>0.5</max_linear_velocity>
         <min_linear_velocity>-0.5</min_linear_velocity>

         <max_angular_velocity>1.0</max_angular_velocity>
         <min_angular_velocity>-1.0</min_angular_velocity>

         <max_linear_acceleration>1.0</max_linear_acceleration>
         <min_linear_acceleration>-1.0</min_linear_acceleration>

         <max_angular_acceleration>2.0</max_angular_acceleration>
         <min_angular_acceleration>-2.0</min_angular_acceleration>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin name="gz::sim::systems::JointStatePublisher" filename="gz-sim-joint-state-publisher-system">
          
          <joint_name>left_front_wheel_joint</joint_name>
          <joint_name>left_back_wheel_joint</joint_name>
          <joint_name>right_front_wheel_joint</joint_name>
          <joint_name>right_back_wheel_joint</joint_name>

          <update_rate>30</update_rate>

        </plugin>
    </gazebo>    
    
     <gazebo>
        <plugin name="gz::sim::systems::OdometryPublisher" filename="gz-sim-odometry-publisher-system">
        
        <odom_frame>odom</odom_frame>
        <robot_base_frame>base_footprint</robot_base_frame>
        <odom_topic>odom</odom_topic>
        <tf_topic>/tf</tf_topic>
        <odom_publish_frequency>50</odom_publish_frequency>

        </plugin>
    </gazebo>    
    
    <link name="base_link">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="5.0"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>

        <visual name="">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>
            <material name="">
                <color rgba="0.5 0.0 0.0 1.0"/>
                <texture filename=""/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>
        </collision>
    </link>

    <link name="right_back_wheel_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
        <inertia 
         ixx="0.01" ixy="0.0" ixz="0.0"
         iyy="0.01" iyz="0.0"
         izz="0.01"/>
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="1.57 0 0"/> 
            <geometry>
                <cylinder radius="0.07" length="0.02"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <geometry>
                <cylinder radius="0.07" length="0.02"/>
            </geometry>
        </collision>
    </link>

    <joint name="right_back_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_back_wheel_link"/>
        <origin xyz="-0.15 -0.26 -0.1" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

<link name="right_front_wheel_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
        <inertia 
         ixx="0.01" ixy="0.0" ixz="0.0"
         iyy="0.01" iyz="0.0"
         izz="0.01"/>
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="1.57 0 0"/> 
            <geometry>
                <cylinder radius="0.07" length="0.02"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <geometry>
                <cylinder radius="0.07" length="0.02"/>
            </geometry>
        </collision>
    </link>

    <joint name="right_front_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_front_wheel_link"/>
        <origin xyz="0.15 -0.26 -0.1" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <link name="left_back_wheel_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
        <inertia 
         ixx="0.01" ixy="0.0" ixz="0.0"
         iyy="0.01" iyz="0.0"
         izz="0.01"/>
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="1.57 0 0"/> 
            <geometry>
                <cylinder radius="0.07" length="0.02"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <geometry>
                <cylinder radius="0.07" length="0.02"/>
            </geometry>
        </collision>
    </link>

    <joint name="left_back_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_back_wheel_link"/>
        <origin xyz="-0.15 0.26 -0.1" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <link name="left_front_wheel_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
        <inertia 
         ixx="0.01" ixy="0.0" ixz="0.0"
         iyy="0.01" iyz="0.0"
         izz="0.01"/>
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="1.57 0 0"/> 
            <geometry>
                <cylinder radius="0.07" length="0.02"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <geometry>
                <cylinder radius="0.07" length="0.02"/>
            </geometry>
        </collision>
    </link>

    <joint name="left_front_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_front_wheel_link"/>
        <origin xyz="0.15 0.26 -0.1" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

</robot>




  